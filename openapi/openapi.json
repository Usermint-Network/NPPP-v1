{
  "openapi": "3.1.0",
  "info": {
    "title": "NPPP v1 Reference API",
    "version": "1.0.0",
    "summary": "Reference HTTP binding for the Notarized Proof of Provenance Protocol.",
    "description": "This OpenAPI document describes a reference HTTP binding for NPPP v1. The normative protocol definition remains in spec/NPPP_v1.md. This document is non-normative and does not redefine protocol semantics. Authentication, metering, pricing, and access policies are implementation-specific.",
    "contact": {
      "name": "UserMint Network",
      "email": "support@usermintnetwork.com"
    },
    "license": {
      "name": "MIT",
      "identifier": "MIT"
    }
  },
  "servers": [
    {
      "url": "https://api.usermintnetwork.com",
      "description": "Reference production API"
    }
  ],
  "tags": [
    {
      "name": "system",
      "description": "System health endpoints."
    },
    {
      "name": "auth",
      "description": "Reference implementation bootstrap and access-related endpoints."
    },
    {
      "name": "notarization",
      "description": "Proof creation endpoints."
    },
    {
      "name": "verification",
      "description": "Replay verification endpoints."
    },
    {
      "name": "proofs",
      "description": "Proof record retrieval endpoints."
    }
  ],
