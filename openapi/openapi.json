    "/v1/notarize": {
      "post": {
        "tags": [
          "notarization"
        ],
        "summary": "Notarize",
        "description": "Creates a proof from a canonicalized evidence bundle using the reference HTTP binding for NPPP v1. This endpoint is implementation-specific and non-normative.",
        "operationId": "notarize_v1_notarize_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NotarizeRequest"
              },
              "examples": {
                "example-1": {
                  "value": {
                    "service": "example-service",
                    "artifact_type": "json",
                    "freshness": "now",
                    "evidence": {
                      "path": "bundle/"
                    }
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotarizeResponse"
                },
                "examples": {
                  "success": {
                    "value": {
                      "proof_id": "nppp_0f7a14b30117",
                      "proof": "NPPP:V1|project=<project>|region=<region>|service=example-service|freshness=now|bundle=<bundle_uri>|sha256=<sha256>|created=<timestamp>",
                      "bundle": "gs://example/bundles/abc.json",
                      "bundle_sha256": "10fa833533b76d3dcc74b06a07cdf44a778ef799fdfa34b87bc99b2500e7f148",
                      "created_at": "2026-03-28T05:58:21Z",
                      "developer_quota": {
                        "free_remaining": 19,
                        "billable_rate_usd": "0.10"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Error Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "402": {
            "description": "Error Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Error Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": [],
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/verify": {
      "post": {
        "tags": [
          "verification"
        ],
        "summary": "Verify",
        "description": "Performs stateless replay verification by retrieving the referenced bundle, recomputing SHA-256, and comparing it to the proof commitment.",
        "operationId": "verify_v1_verify_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyRequest"
              },
              "examples": {
                "example-1": {
                  "value": {
                    "proof": "NPPP:V1|project=<project>|region=<region>|service=example-service|freshness=now|bundle=<bundle_uri>|sha256=<sha256>|created=<timestamp>"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifyResponse"
                },
                "examples": {
                  "success": {
                    "value": {
                      "verified": true,
                      "expected_sha256": "10fa833533b76d3dcc74b06a07cdf44a778ef799fdfa34b87bc99b2500e7f148",
                      "computed_sha256": "10fa833533b76d3dcc74b06a07cdf44a778ef799fdfa34b87bc99b2500e7f148",
                      "bundle": "gs://example/bundles/abc.json",
                      "status": "SHA Replay Verified: OK"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Error Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/v1/proof/{proof_id}": {
      "get": {
        "tags": [
          "proofs"
        ],
        "summary": "Get Proof",
        "description": "Retrieves a stored proof record. Proof record retrieval does not itself constitute replay verification.",
        "operationId": "get_proof_v1_proof__proof_id__get",
        "parameters": [
          {
            "required": true,
            "schema": {
              "type": "string",
              "title": "Proof Id"
            },
            "name": "proof_id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProofRecordResponse"
                },
                "examples": {
                  "success": {
                    "value": {
                      "proof_id": "nppp_0f7a14b30117",
                      "proof": "NPPP:V1|...",
                      "bundle": "gs://example/bundles/abc.json",
                      "bundle_sha256": "10fa833533b76d3dcc74b06a07cdf44a778ef799fdfa34b87bc99b2500e7f148",
                      "created_at": "2026-03-28T05:58:21Z",
                      "service": "example-service",
                      "artifact_type": "json",
                      "freshness": "now",
                      "verification": {
                        "status": "unverified",
                        "model": "stateless"
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Error Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
