    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Reference implementation outer access credential. Non-normative and implementation-specific."
      },
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Reference implementation metering key for selected operations. Non-normative and implementation-specific."
      }
    }
  }
}
