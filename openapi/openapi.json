            "user": {
              "id": "user_1234567890",
              "email": "developer@example.com",
              "stripe_customer_id": null,
              "created_at": "2026-04-02T00:00:00Z"
            },
            "api_key": "usermint_sk_1234567890"
          }
        ]
      },
      "EvidenceInput": {
        "properties": {
          "path": {
            "type": "string",
            "title": "Path"
          }
        },
        "type": "object",
        "required": [
          "path"
        ],
        "title": "EvidenceInput"
      },
      "NotarizeRequest": {
        "properties": {
          "service": {
            "type": "string",
            "title": "Service"
          },
          "artifact_type": {
            "type": "string",
            "title": "Artifact Type"
          },
          "freshness": {
            "type": "string",
            "title": "Freshness"
          },
          "evidence": {
            "$ref": "#/components/schemas/EvidenceInput"
          }
        },
        "type": "object",
        "required": [
          "service",
          "artifact_type",
          "freshness",
          "evidence"
        ],
        "title": "NotarizeRequest"
      },
      "NotarizeResponse": {
        "properties": {
          "proof_id": {
            "type": "string",
            "pattern": "^nppp_[A-Za-z0-9_-]+$"
          },
          "proof": {
            "type": "string",
            "title": "Proof"
          },
          "bundle": {
            "type": "string",
            "title": "Bundle"
          },
          "bundle_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "type": "object",
        "required": [
          "proof_id",
          "proof",
          "bundle",
          "bundle_sha256",
          "created_at"
        ],
        "title": "NotarizeResponse"
      },
      "ProofRecordResponse": {
        "properties": {
          "proof_id": {
            "type": "string",
            "pattern": "^nppp_[A-Za-z0-9_-]+$"
          },
          "proof": {
            "type": "string",
            "title": "Proof"
          },
          "bundle": {
            "type": "string",
            "title": "Bundle"
          },
          "bundle_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "service": {
            "type": "string",
            "title": "Service"
          },
          "artifact_type": {
            "type": "string",
            "title": "Artifact Type"
          },
          "freshness": {
            "type": "string",
            "title": "Freshness"
          },
          "verification": {
            "$ref": "#/components/schemas/VerificationState"
          }
        },
        "type": "object",
        "required": [
          "proof_id",
          "proof",
          "bundle",
          "bundle_sha256",
          "created_at",
          "service",
          "artifact_type",
          "freshness",
          "verification"
        ],
        "title": "ProofRecordResponse"
      },
      "VerificationState": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "unverified"
            ]
          },
          "model": {
            "type": "string",
            "enum": [
              "stateless"
            ]
          }
        },
        "required": [
          "status",
          "model"
        ]
      },
      "VerifyRequest": {
        "properties": {
          "proof": {
            "type": "string",
            "title": "Proof"
          }
        },
        "type": "object",
        "required": [
          "proof"
        ],
        "title": "VerifyRequest"
      },
      "VerifyResponse": {
        "properties": {
          "verified": {
            "type": "boolean",
            "title": "Verified"
          },
          "expected_sha256": {
            "type": "string",
            "title": "Expected Sha256"
          },
          "computed_sha256": {
            "type": "string",
            "title": "Computed Sha256"
          },
          "bundle": {
            "type": "string",
            "title": "Bundle"
          },
          "status": {
            "type": "string",
            "enum": [
              "SHA Replay Verified: OK",
              "SHA Replay Verified: FAILED"
            ],
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "verified",
          "expected_sha256",
          "computed_sha256",
          "bundle",
          "status"
        ],
        "title": "VerifyResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
