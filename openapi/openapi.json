    "/v1/auth/bootstrap": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Bootstrap",
        "description": "Reference-implementation-specific bootstrap endpoint. This route is non-normative and not part of the core NPPP v1 protocol.",
        "operationId": "bootstrap_v1_auth_bootstrap_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BootstrapRequest"
              },
              "examples": {
                "example-1": {
                  "value": {
                    "email": "developer@example.com"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BootstrapResponse"
                },
                "examples": {
                  "success": {
                    "value": {
                      "user": {
                        "id": "user_1234567890",
                        "email": "developer@example.com",
                        "stripe_customer_id": null,
                        "created_at": "2026-04-02T00:00:00Z"
                      },
                      "api_key": "usermint_sk_1234567890"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Error Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/notarize": {
      "post": {
        "tags": [
          "notarization"
        ],
        "summary": "Notarize",
        "description": "Creates a proof from a canonicalized evidence bundle using the reference HTTP binding for NPPP v1. This endpoint is implementation-specific and non-normative, but its proof and verification semantics are governed by the NPPP v1 specification.",
        "operationId": "notarize_v1_notarize_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NotarizeRequest"
              },
              "examples": {
                "example-1": {
                  "value": {
                    "service": "example-service",
                    "artifact_type": "json",
                    "freshness": "now",
                    "evidence": {
                      "path": "bundle/example.json"
                    }
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotarizeResponse"
                },
                "examples": {
                  "success": {
                    "value": {
                      "proof_id": "nppp_0f7a14b30117",
                      "proof": "NPPP:V1|project=usermint-network|region=us-central1|service=example-service|freshness=now|bundle=gs://example/bundles/abc.json|sha256=10fa833533b76d3dcc74b06a07cdf44a778ef799fdfa34b87bc99b2500e7f148|created=2026-03-28T05:58:21Z",
                      "bundle": "gs://example/bundles/abc.json",
                      "bundle_sha256": "10fa833533b76d3dcc74b06a07cdf44a778ef799fdfa34b87bc99b2500e7f148",
                      "created_at": "2026-03-28T05:58:21Z"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Error Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "402": {
            "description": "Error Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Error Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": [],
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/verify": {
      "post": {
        "tags": [
          "verification"
        ],
        "summary": "Verify",
        "description": "Performs stateless replay verification by retrieving the referenced bundle, recomputing SHA-256, and comparing it to the proof commitment.",
        "operationId": "verify_v1_verify_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyRequest"
              },
              "examples": {
                "example-1": {
                  "value": {
                    "proof": "NPPP:V1|project=usermint-network|region=us-central1|service=example-service|freshness=now|bundle=gs://example/bundles/abc.json|sha256=10fa833533b76d3dcc74b06a07cdf44a778ef799fdfa34b87bc99b2500e7f148|created=2026-03-28T05:58:21Z"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifyResponse"
                },
                "examples": {
                  "success": {
                    "value": {
                      "verified": true,
                      "expected_sha256": "10fa833533b76d3dcc74b06a07cdf44a778ef799fdfa34b87bc99b2500e7f148",
                      "computed_sha256": "10fa833533b76d3dcc74b06a07cdf44a778ef799fdfa34b87bc99b2500e7f148",
                      "bundle": "gs://example/bundles/abc.json",
                      "status": "SHA Replay Verified: OK"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Error Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/proof/{proof_id}": {
      "get": {
        "tags": [
          "proofs"
        ],
        "summary": "Get Proof",
        "description": "Retrieves a stored proof record. Proof record retrieval does not itself constitute replay verification.",
        "operationId": "get_proof_v1_proof__proof_id__get",
        "parameters": [
          {
            "required": true,
            "schema": {
              "type": "string",
              "title": "Proof Id"
            },
            "name": "proof_id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProofRecordResponse"
                },
                "examples": {
                  "success": {
                    "value": {
                      "proof_id": "nppp_0f7a14b30117",
                      "proof": "NPPP:V1|project=usermint-network|region=us-central1|service=example-service|freshness=now|bundle=gs://example/bundles/abc.json|sha256=10fa833533b76d3dcc74b06a07cdf44a778ef799fdfa34b87bc99b2500e7f148|created=2026-03-28T05:58:21Z",
                      "bundle": "gs://example/bundles/abc.json",
                      "bundle_sha256": "10fa833533b76d3dcc74b06a07cdf44a778ef799fdfa34b87bc99b2500e7f148",
                      "created_at": "2026-03-28T05:58:21Z",
                      "service": "example-service",
                      "artifact_type": "json",
                      "freshness": "now",
                      "verification": {
                        "status": "unverified",
                        "model": "stateless"
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Error Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
